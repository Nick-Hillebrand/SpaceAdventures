# NASA
NASA_API_KEY=DEMO_KEY

# N2YO (ISS tracker)
N2YO_API_KEY=

# Launch Library 2 (no key required)
LL2_BASE_URL=https://ll.thespacedevs.com/2.2.0

# DeepL (translation of launch/APOD/etc. text into de/fr/es/ja/ru). Missing
# key falls back to English text, it does not fail the sync.
DEEPL_API_KEY=
DEEPL_BASE_URL=https://api-free.deepl.com

# JWT
JWT_SECRET_KEY=change-me-to-a-random-string-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600

# Unsubscribe links & admin endpoints
UNSUBSCRIBE_SECRET_KEY=change-me-to-a-random-string-at-least-32-characters-long
ADMIN_API_KEY=change-me-to-a-random-string-at-least-32-characters-long

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Frontend origin (CORS)
FRONTEND_ORIGIN=http://localhost:5173

# Secrets enforcement — set to 1 in prod so the app refuses to start without
# JWT_SECRET_KEY/UNSUBSCRIBE_SECRET_KEY/ADMIN_API_KEY (each >= 32 chars).
# Leave unset (0) for local dev.
APP_REQUIRE_SECRETS=0

# Refresh-token cookie Secure attribute — true in prod, false only for
# plain-HTTP local dev.
COOKIE_SECURE=true

# Honor X-Forwarded-For for IP-based rate limiting — true only when behind a
# proxy you control (Caddy in prod), never in dev.
TRUST_PROXY_HEADERS=false

# Serve /docs and /openapi.json — enable only in non-prod deploys.
EXPOSE_DOCS=false

# Run the APScheduler job registry inside this process (17-worker-and-scheduling.md
# P3.1). docker-compose.yml sets this directly for the dev backend container;
# set it here too if you run `uvicorn` directly (not via docker compose) and
# want background jobs (LL2 sync, notifications, etc.) locally. Never set this
# in prod — docker-compose.prod.yml runs a dedicated `worker` service instead
# and the backend web tier stays stateless.
SCHEDULER_IN_APP=0

# Sentry error reporting (P3.6). Leave blank to disable — Sentry is never a
# hard dependency.
SENTRY_DSN=

# Web Push / VAPID (19-notification-channels-v2.md B1.2). Both values are
# raw base64url (unpadded), not PEM — VAPID_PUBLIC_KEY is consumed directly
# by the browser's PushManager.subscribe(), VAPID_PRIVATE_KEY by pywebpush's
# Vapid.from_string(). Generate a keypair with:
#   python -c "
#   from py_vapid import Vapid02
#   from py_vapid.utils import b64urlencode
#   from cryptography.hazmat.primitives import serialization
#   v = Vapid02(); v.generate_keys()
#   print('VAPID_PUBLIC_KEY=' + b64urlencode(v.public_key.public_bytes(
#       serialization.Encoding.X962, serialization.PublicFormat.UncompressedPoint)))
#   print('VAPID_PRIVATE_KEY=' + b64urlencode(
#       v.private_key.private_numbers().private_value.to_bytes(32, 'big')))
#   "
# Leave blank to disable push sending (subscribe/unsubscribe endpoints still
# work, but /push/vapid-public-key returns an empty key and the frontend
# won't offer the push channel).
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=
